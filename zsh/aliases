wallset() {
  f=$(ls $HOME/.wallpapers | grep -v "active.jpg" | fzf)
  cp "$HOME/.wallpapers/$f" "$HOME/.wallpapers/active.jpg"
  lule -n --image=/home/loric/.wallpapers/active.jpg --palette=convert set
}

fmpv() {
  if [ -z "$1" ]; then
    mpv "$(find $HOME/Videos/* | rofi -dmenu)"
  else
    mpv "$(find "$1" | rofi -dmenu)"
  fi
}
