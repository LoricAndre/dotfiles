n() {
  if [ -d $@ ]; then
    p=$HOME/.config/nvim/session/$(echo `cd $@ && pwd` | sed -e 's#/##g').vim
    nvim -S "$p" -c "silent! Obsess $p"
  else
    nvim $@
  fi
}


N() {
  file=$(ls ~/Dropbox/notes | fzf)
  n=$(echo $file | sed 's/\.txt//')
  echo $n >> ~/.log
  nvim "note:$n"
}
