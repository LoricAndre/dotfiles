compdef _files mcd


dotadd() {
  for f in "$@"
  do
    i=$(echo $f | rev | cut -d'/' -f1 | rev)
    mv $f ~/dotfiles/ &&
    ln -s "/home/loric/dotfiles/$i" "$f" &&
    echo "Moved $f to ~/dotfiles/$i and softlinked it back"
  done
}

dotlink() {
  ln -s "$(pwd)/$1" $2
}

nalias() {
  echo "alias $1='$2'" >> $HOME/dotfiles/aliases.zsh
}
