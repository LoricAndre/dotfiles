j() {
    if [[ "$#" -ne 0 ]]; then
        cd $(autojump $@)
        return
    fi
    cd "$(autojump -s | sort -k1gr | awk '$1 ~ /[0-9]:/ && $2 ~ /^\// { for (i=2; i<=NF; i++) { print $(i) } }' |  fzf --height 40% --reverse --inline-info)" 
}

packadd() {
  for arg in "$@"; do
    echo $arg >> $HOME/dotfiles/packages
  done
}

open() {
  for a in "$@"; do
    xdg-open $a >/dev/null 2>&1
  done
}
