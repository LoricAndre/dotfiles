<colorclass>            <border> <background> <text>  <indicator> <child_border>
client.focused          %{{color1}}  %{{background}}  %{{foreground}} %{{color3}}     %{{color5}}
client.focused_inactive %{{color5}}  %{{background}}  %{{foreground}} %{{color3}}     %{{color5}}
client.unfocused        %{{color7}}  %{{background}}  %{{foreground}} %{{color3}}     %{{color5}}
client.urgent           %{{color13}} %{{background}}  %{{foreground}} %{{background}}     %{{background}}
client.placeholder      %{{background}}  %{{background}}      %{{foreground}} %{{background}} %{{background}}

client.background       %{{foreground}}
