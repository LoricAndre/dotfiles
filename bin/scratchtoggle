#!/usr/bin/env bash
scratch() {
  echo $1
  if $1; then
    mode=windowmap
  else
    mode=windowunmap
  fi
  echo $mode
  w=$(xdotool search --class scratchterm | tail -n 1)
  echo $w
  xdotool $mode $w
  if [ $1 == true ]; then
    next=false
  else
    next=true
  fi
  herbstclient keybind Mod4-t spawn "/home/loric/dotfiles/scratchtoggle $next"
}
hide() {
  w=$(xdotool search --class scratchterm | tail -n 1)
  xdotool windowminimize $w
}

show() {
  w=$(xdotool search --class scratchterm | tail -n 1)
  echo $w
  xdotool windowraise $w
}

if [ -z $(xdotool search --onlyvisible --class scratchterm) ]; then
  show
  echo "show"
else 
  hide
  echo "hide"
fi
